{
  "port": 4000,
  "cors": true,
  "logging": true,
  "defaultDelay": 100,
  "routes": [
    {
      "method": "GET",
      "path": "/api/users",
      "status": 200,
      "body": {
        "data": [
          { "id": 1, "name": "Alice", "email": "alice@example.com" },
          { "id": 2, "name": "Bob", "email": "bob@example.com" }
        ],
        "total": 2
      },
      "description": "List all users"
    },
    {
      "method": "GET",
      "path": "/api/users/:id",
      "status": 200,
      "body": { "id": "{{params.id}}", "name": "User {{params.id}}", "email": "user{{params.id}}@example.com" },
      "description": "Get user by ID (dynamic)"
    },
    {
      "method": "POST",
      "path": "/api/users",
      "status": 201,
      "body": { "id": 3, "created": true },
      "description": "Create user"
    },
    {
      "method": "DELETE",
      "path": "/api/users/:id",
      "status": 204,
      "description": "Delete user"
    },
    {
      "method": "GET",
      "path": "/api/health",
      "status": 200,
      "body": { "status": "ok" },
      "description": "Health check"
    },
    {
      "method": "POST",
      "path": "/api/login",
      "status": 200,
      "body": { "token": "mock-jwt-token-123" },
      "delay": 200,
      "description": "Login (200ms delay)"
    }
  ]
}
